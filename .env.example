# Copy this file to `.env` and fill in real values.
# Never commit `.env` (see .gitignore).

# --- LLM ---
OPENAI_API_KEY=sk-...
# Any chat-completions / responses-capable model. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=gpt-4o-mini

# --- News provider (default: NewsAPI) ---
# Get a key at https://newsapi.org/
NEWS_API_KEY=

# Which news provider to use. Currently supported: newsapi
NEWS_PROVIDER=newsapi

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=app-password-or-token
EMAIL_FROM=you@example.com
# Comma-separated list of recipients
EMAIL_TO=recipient1@example.com,recipient2@example.com

# --- Run-time tuning ---
# How far back to search for news (hours)
LOOKBACK_HOURS=36
# Default cap per topic (can also be overridden per-topic in topics.yaml)
MAX_ARTICLES_PER_TOPIC=8
# Where to write the generated .pptx
OUTPUT_DIR=output
# Path to topic config file (defaults to ./topics.yaml at repo root)
TOPICS_FILE=topics.yaml
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Intelligence sources ---
# Master switches per source. Either can be flipped to false for ad-hoc runs.
ENABLE_NEWS_SOURCE=true
ENABLE_LAUNCH_SOURCE=true

# Launch source (The Space Devs Launch Library 2 by default).
# Leave LAUNCH_API_BASE_URL empty to use the public LL2 endpoint, or pin a
# private mirror / paid plan, e.g. https://lldev.thespacedevs.com/2.2.0
LAUNCH_API_BASE_URL=
# Look-ahead window for upcoming launches (days)
LAUNCH_LOOKAHEAD_DAYS=30
# When false, only launches relevant to tracked entities are kept.
INCLUDE_ALL_LAUNCHES=false

# Where to persist normalized intelligence events (JSONL, append-only).
EVENTS_STORE_PATH=output/events.jsonl
